{
  "name": "donation-management",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "turbo run dev --filter=@donation/web",
    "dev:mobile": "turbo run dev --filter=@donation/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:migrate": "cd packages/supabase && supabase db push",
    "db:reset": "cd packages/supabase && supabase db reset"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "packageManager": "npm@10.0.0"
}
